{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Climate",
  "version": "0.1.0",
  "identifier": "net.mycelix.climate",
  "build": {
    "frontendDist": "../../leptos/dist",
    "devUrl": "http://localhost:8103",
    "beforeBuildCommand": "cd ../../leptos && trunk build --release",
    "beforeDevCommand": "cd ../../leptos && trunk serve --port 8103"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Climate — Mycelix",
        "width": 1280,
        "height": 800,
        "minWidth": 360,
        "minHeight": 640,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline' https:; connect-src 'self' https: wss: ws://localhost:*; font-src 'self' https: data:; img-src 'self' https: data: blob:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  },
  "plugins": {
    "shell": { "open": true }
  }
}
