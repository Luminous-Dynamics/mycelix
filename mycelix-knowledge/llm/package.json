{
  "name": "@mycelix/knowledge-llm",
  "version": "0.1.0",
  "description": "LLM integration for Mycelix Knowledge - epistemic classification, evidence extraction, and fact-checking",
  "main": "dist/analyzer.js",
  "module": "dist/analyzer.esm.js",
  "types": "dist/analyzer.d.ts",
  "exports": {
    ".": {
      "import": "./dist/analyzer.esm.js",
      "require": "./dist/analyzer.js",
      "types": "./dist/analyzer.d.ts"
    },
    "./providers": {
      "import": "./dist/providers/index.esm.js",
      "require": "./dist/providers/index.js",
      "types": "./dist/providers/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "node-fetch": "^3.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Luminous-Dynamics/mycelix-knowledge.git",
    "directory": "llm"
  },
  "author": "Luminous Dynamics <dev@luminousdynamics.org>",
  "keywords": [
    "mycelix",
    "knowledge",
    "llm",
    "ai",
    "epistemic",
    "classification",
    "fact-check",
    "openai",
    "anthropic",
    "ollama"
  ],
  "license": "AGPL-3.0-or-later",
  "bugs": {
    "url": "https://github.com/Luminous-Dynamics/mycelix-knowledge/issues"
  },
  "homepage": "https://knowledge.mycelix.net/integrations/llm",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
