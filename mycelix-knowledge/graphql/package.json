{
  "name": "@mycelix/knowledge-graphql",
  "version": "0.1.0",
  "description": "GraphQL API for Mycelix Knowledge decentralized knowledge graph",
  "main": "dist/server.js",
  "module": "dist/server.esm.js",
  "types": "dist/server.d.ts",
  "exports": {
    ".": {
      "import": "./dist/server.esm.js",
      "require": "./dist/server.js",
      "types": "./dist/server.d.ts"
    },
    "./schema": {
      "import": "./schema.graphql"
    }
  },
  "scripts": {
    "dev": "tsx watch server.ts",
    "start": "node dist/server.js",
    "build": "tsc",
    "codegen": "graphql-codegen --config codegen.ts",
    "generate:types": "graphql-codegen"
  },
  "dependencies": {
    "@apollo/server": "^4.10.0",
    "@graphql-tools/schema": "^10.0.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "graphql": "^16.8.0",
    "graphql-subscriptions": "^2.0.0",
    "graphql-ws": "^5.14.0",
    "ws": "^8.14.0"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^5.0.0",
    "@graphql-codegen/typescript": "^4.0.0",
    "@graphql-codegen/typescript-resolvers": "^4.0.0",
    "@types/cors": "^2.8.15",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/ws": "^8.5.10",
    "tsx": "^4.6.0",
    "typescript": "^5.3.0"
  },
  "peerDependencies": {
    "@mycelix/knowledge-client": "^0.1.0"
  },
  "files": [
    "dist",
    "schema.graphql"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Luminous-Dynamics/mycelix-knowledge.git",
    "directory": "graphql"
  },
  "author": "Luminous Dynamics <dev@luminousdynamics.org>",
  "keywords": [
    "mycelix",
    "knowledge",
    "graphql",
    "holochain",
    "epistemic",
    "fact-checking"
  ],
  "license": "AGPL-3.0-or-later",
  "bugs": {
    "url": "https://github.com/Luminous-Dynamics/mycelix-knowledge/issues"
  },
  "homepage": "https://knowledge.mycelix.net/api/graphql",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
