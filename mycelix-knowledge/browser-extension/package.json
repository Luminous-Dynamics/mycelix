{
  "name": "@mycelix/knowledge-browser-extension",
  "version": "0.1.0",
  "private": true,
  "description": "Fact-check any text on the web using the Mycelix decentralized knowledge graph",
  "scripts": {
    "build": "npm run build:chrome && npm run build:firefox",
    "build:chrome": "node scripts/build.js chrome",
    "build:firefox": "node scripts/build.js firefox",
    "package": "npm run package:chrome && npm run package:firefox",
    "package:chrome": "cd dist/chrome && zip -r ../mycelix-knowledge-chrome.zip .",
    "package:firefox": "cd dist/firefox && zip -r ../mycelix-knowledge-firefox.zip .",
    "clean": "rm -rf dist",
    "lint": "eslint *.js",
    "test": "jest"
  },
  "devDependencies": {
    "archiver": "^6.0.0",
    "eslint": "^8.50.0",
    "fs-extra": "^11.2.0",
    "jest": "^29.7.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Luminous-Dynamics/mycelix-knowledge.git",
    "directory": "browser-extension"
  },
  "author": "Luminous Dynamics <dev@luminousdynamics.org>",
  "license": "AGPL-3.0-or-later"
}
