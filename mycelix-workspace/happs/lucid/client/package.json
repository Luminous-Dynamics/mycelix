{
  "name": "@mycelix/lucid-client",
  "version": "0.1.0",
  "description": "TypeScript client SDK for the LUCID Personal Knowledge Graph hApp",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --out-dir dist"
  },
  "files": [
    "dist",
    "src"
  ],
  "peerDependencies": {
    "@holochain/client": ">=0.18.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "~5.0.0"
  }
}
