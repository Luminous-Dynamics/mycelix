{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LUCID",
  "version": "0.1.0",
  "identifier": "com.mycelix.lucid",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "LUCID",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "transparent": false
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "menuOnLeftClick": false
    },
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "targets": ["deb", "rpm"],
    "category": "Productivity",
    "shortDescription": "Personal Knowledge Graph",
    "longDescription": "LUCID is your decentralized personal knowledge management system built on Holochain. Capture, organize, and discover insights with E/N/M/H classification, semantic search, and collective sensemaking.",
    "linux": {
      "appimage": {
        "bundleMediaFramework": true
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "wix": null
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "notification": {
      "all": true
    },
    "dialog": {
      "all": true
    },
    "fs": {
      "all": true,
      "scope": ["$HOME/.lucid/**", "$APPDATA/lucid/**", "$DATA/lucid/**"]
    },
    "clipboard-manager": {
      "all": true
    }
  }
}
