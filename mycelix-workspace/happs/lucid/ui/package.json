    "@tauri-apps/cli": "^2.2.3",
    "@types/d3": "^7.4.3",
    "@types/katex": "^0.16.8",
    "@types/node": "^24.10.1",
    "@vitest/ui": "^4.0.18",
    "jsdom": "^27.4.0",
    "svelte": "^5.43.8",
    "svelte-check": "^4.3.4",
    "typescript": "~5.9.3",
    "vite": "^6.0.7",
    "vitest": "^4.0.18"
