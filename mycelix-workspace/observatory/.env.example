# Mycelix Observatory Configuration
#
# Copy this file to .env and adjust values for your environment.
# All variables prefixed with VITE_ are exposed to the browser.

# Holochain Conductor WebSocket URL (App Interface)
# The observatory connects here for live data. If unavailable, falls back to demo mode.
VITE_CONDUCTOR_URL=ws://localhost:8888

# Admin WebSocket URL (for conductor management / health checks)
VITE_ADMIN_URL=ws://localhost:8889

# Set to "true" to allow fallback to simulated data when conductor is unavailable
VITE_FALLBACK_TO_SIMULATION=true

# Public API endpoint (Gateway) - used in production
# VITE_API_URL=https://api.mycelix.net

# Feature flags
# VITE_ENABLE_LIVE_METRICS=true
# VITE_ENABLE_NETWORK_GRAPH=true

# Dashboard refresh interval in milliseconds (default: 10000)
# VITE_REFRESH_INTERVAL=10000
