# Mycelix Production Environment Variables
# Copy this file to .env and fill in real values before deploying.
#
#   cp .env.example .env
#   openssl rand -base64 32  # generate LAIR_PASSPHRASE

# --- Lair Keystore ---
# Passphrase for the Holochain Lair keystore (encrypts agent keys at rest).
# Generate with: openssl rand -base64 32
# CRITICAL: back this up. Losing it means losing access to all agent keys.
LAIR_PASSPHRASE=<generate-with-openssl-rand-base64-32>

# --- Conductor Ports ---
# Admin interface: for hApp installation, agent management (internal only)
CONDUCTOR_ADMIN_PORT=4444
# App interface: for zome calls from Observatory and SDK clients
CONDUCTOR_APP_PORT=8888

# --- Observatory ---
# Port the SvelteKit dashboard listens on (behind nginx)
OBSERVATORY_PORT=3000

# --- TLS ---
# Paths to TLS certificate and private key (inside the nginx container).
# For Let's Encrypt, mount /etc/letsencrypt as a volume and use:
#   TLS_CERT_PATH=/etc/letsencrypt/live/mycelix.net/fullchain.pem
#   TLS_KEY_PATH=/etc/letsencrypt/live/mycelix.net/privkey.pem
TLS_CERT_PATH=/etc/ssl/certs/mycelix.crt
TLS_KEY_PATH=/etc/ssl/private/mycelix.key

# --- Holochain Network ---
# Bootstrap service: initial peer discovery for joining the DHT network
BOOTSTRAP_URL=https://bootstrap.holo.host
# Signal server: WebRTC handshake facilitator for NAT traversal
SIGNAL_URL=wss://signal.holo.host

# --- Observatory Build Args ---
# These are baked into the SvelteKit build. Override during `docker-compose build`.
VITE_CONDUCTOR_URL=ws://conductor:8888
VITE_FALLBACK_TO_SIMULATION=true
VITE_ENABLE_LIVE_METRICS=true
VITE_ENABLE_NETWORK_GRAPH=true
