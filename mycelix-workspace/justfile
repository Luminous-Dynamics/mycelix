# Verify WASM build artifacts exist
verify-builds:
    #!/usr/bin/env bash
    set -euo pipefail
    echo ""
    echo "Verifying WASM Build Artifacts"
    echo "=============================="
    echo ""
    for happ in epistemic-markets fabrication edunet marketplace mail supplychain core identity governance knowledge; do
        echo "Checking $happ..."
        if [ -d "happs/$happ" ]; then
            wasm_count=$(find -L "happs/$happ" -name "*.wasm" 2>/dev/null | wc -l)
            dna_count=$(find -L "happs/$happ" -name "*.dna" 2>/dev/null | wc -l)
            happ_count=$(find -L "happs/$happ" -name "*.happ" 2>/dev/null | wc -l)
            if [ "$wasm_count" -gt 0 ]; then
                echo "  [OK] WASM: $wasm_count files"
            else
                echo "  [--] WASM: No artifacts found"
            fi
            if [ "$dna_count" -gt 0 ]; then
                echo "  [OK] DNA:  $dna_count bundles"
            else
                echo "  [..] DNA:  No bundles found"
            fi
            if [ "$happ_count" -gt 0 ]; then
                echo "  [OK] hApp: $happ_count packages"
            else
                echo "  [..] hApp: No packages found"
            fi
        else
            echo "  [--] Directory not found"
        fi
        echo ""
    done

# Verify all hApps can compile to WASM (comprehensive build test)
verify-all-builds:
    #!/usr/bin/env bash
    set -euo pipefail
    echo ""
    echo "🔨 Comprehensive Build Verification"
    echo "===================================="
    echo ""

    passed=0
    failed=0
    skipped=0

    # Core hApps with Cargo.toml
    for happ_dir in /srv/luminous-dynamics/mycelix-identity \
                    /srv/luminous-dynamics/mycelix-governance \
                    /srv/luminous-dynamics/mycelix-knowledge \
                    /srv/luminous-dynamics/mycelix-finance; do
        name=$(basename "$happ_dir")
        if [ -f "$happ_dir/Cargo.toml" ]; then
            echo -n "Building $name... "
            if cd "$happ_dir" && cargo build --release --target wasm32-unknown-unknown 2>/dev/null; then
                wasm_count=$(find target/wasm32-unknown-unknown/release -maxdepth 1 -name "*.wasm" 2>/dev/null | wc -l)
                echo "✅ ($wasm_count WASM files)"
                ((passed++))
            else
                echo "❌ (build failed)"
                ((failed++))
            fi
        else
            echo "⏭️  $name (no Cargo.toml)"
            ((skipped++))
        fi
    done

    # Workspace native hApps
    cd /srv/luminous-dynamics/mycelix-workspace
    for happ in happs/epistemic-markets happs/fabrication; do
        name=$(basename "$happ")
        if [ -f "$happ/Cargo.toml" ]; then
            echo -n "Building $name... "
            if cd "$happ" && cargo build --release --target wasm32-unknown-unknown 2>/dev/null; then
                wasm_count=$(find target/wasm32-unknown-unknown/release -maxdepth 1 -name "*.wasm" 2>/dev/null | wc -l)
                echo "✅ ($wasm_count WASM files)"
                ((passed++))
            else
                echo "❌ (build failed)"
                ((failed++))
            fi
            cd /srv/luminous-dynamics/mycelix-workspace
        fi
    done

    echo ""
    echo "Summary: $passed passed, $failed failed, $skipped skipped"
    echo ""

    if [ "$failed" -gt 0 ]; then
        exit 1
    fi

# Check symlinks are valid
verify-symlinks:
    #!/usr/bin/env bash
    set -euo pipefail
    echo ""
    echo "Verifying hApp Symlinks"
    echo "======================="
    echo ""
    for happ in happs/*; do
        name=$(basename "$happ")
        if [ -L "$happ" ]; then
            target=$(readlink "$happ")
            if [ -d "$happ" ]; then
                echo "[OK] $name -> $target"
            else
                echo "[!!] $name -> $target (BROKEN)"
            fi
        elif [ -d "$happ" ]; then
            echo "[native] $name"
        fi
    done
    echo ""

