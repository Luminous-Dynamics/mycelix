# Build all hApps to WASM (compilation verification)
build-wasm-all:
    #!/usr/bin/env bash
    set -euo pipefail
    echo ""
    echo "🔨 Building ALL hApps to WASM"
    echo "=============================="
    echo ""

    passed=0
    failed=0
    errors=""

    declare -A HAPPS
    # Cluster DNAs (replace property, housing, care, mutualaid, water, justice, emergency, media)
    HAPPS[commons]="/srv/luminous-dynamics/mycelix-commons"
    HAPPS[civic]="/srv/luminous-dynamics/mycelix-civic"
    # Standalone hApps
    HAPPS[core]="/srv/luminous-dynamics/mycelix-core"
    HAPPS[epistemic-markets]="/srv/luminous-dynamics/mycelix-workspace/happs/epistemic-markets"
    HAPPS[health]="/srv/luminous-dynamics/mycelix-health"
    HAPPS[energy]="/srv/luminous-dynamics/mycelix-energy"
    HAPPS[identity]="/srv/luminous-dynamics/mycelix-identity"
    HAPPS[governance]="/srv/luminous-dynamics/mycelix-governance"
    HAPPS[finance]="/srv/luminous-dynamics/mycelix-finance"
    HAPPS[climate]="/srv/luminous-dynamics/mycelix-climate"
    HAPPS[space]="/srv/luminous-dynamics/mycelix-space"
    HAPPS[consensus]="/srv/luminous-dynamics/mycelix-workspace/happs/consensus"
    HAPPS[fabrication]="/srv/luminous-dynamics/mycelix-workspace/happs/fabrication"

    for name in "${!HAPPS[@]}"; do
        dir="${HAPPS[$name]}"
        if [ -f "$dir/Cargo.toml" ]; then
            echo -n "  $name... "
            if (cd "$dir" && cargo build --target wasm32-unknown-unknown 2>/dev/null); then
                echo "OK"
                ((passed++))
            else
                echo "FAIL"
                ((failed++))
                errors="$errors $name"
            fi
        fi
    done

    echo ""
    echo "Results: $passed passed, $failed failed"
    if [ "$failed" -gt 0 ]; then
        echo "Failed:$errors"
        exit 1
    fi

