# Format all code
fmt:
    @echo "🎨 Formatting code..."
    cd sdk && cargo fmt
    @if [ -f "happs/mail/package.json" ]; then cd happs/mail && pnpm format; fi
    @if [ -f "happs/marketplace/package.json" ]; then cd happs/marketplace && pnpm format; fi
    @if [ -f "observatory/package.json" ]; then cd observatory && pnpm format; fi
    @if [ -d "core/0tml" ]; then cd core/0tml && ruff format .; fi

# Lint all code
lint:
    @echo "🔍 Linting code..."
    cd sdk && cargo clippy -- -D warnings
    @if [ -f "happs/mail/package.json" ]; then cd happs/mail && pnpm lint; fi
    @if [ -d "core/0tml" ]; then cd core/0tml && ruff check .; fi

# Run all checks (format, lint, test)
check: fmt lint test
    @echo "✅ All checks passed!"

# ============================================================
# RELEASE
# ============================================================

# Create a new release
release version:
    @echo "🚀 Creating release v{{version}}..."
    @echo "Updating version numbers..."
    # Update Cargo.toml versions
    @sed -i 's/^version = ".*"/version = "{{version}}"/' sdk/Cargo.toml
    @echo "Running tests..."
    just test
    @echo "Building release artifacts..."
    just build
    @echo "Creating git tag..."
    git add -A
    git commit -m "Release v{{version}}"
    git tag -a "v{{version}}" -m "Release v{{version}}"
    @echo "✅ Release v{{version}} ready!"
    @echo "   Run 'git push && git push --tags' to publish"

