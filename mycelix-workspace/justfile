# Default: show help
default:
    @just --list --unsorted

# ============================================================
# ONE-COMMAND STARTUP (NEW!)
# ============================================================

# 🚀 RECOMMENDED: Build and start everything in one command
up: _ensure-built
    @echo ""
    @echo "🍄 =================================="
    @echo "   MYCELIX ECOSYSTEM STARTING"
    @echo "🍄 =================================="
    @echo ""
    @just _check-deps
    @just stop 2>/dev/null || true
    @echo "🔐 Starting Lair keystore..."
    @mkdir -p .lair
    @lair-keystore server run --piped &>/dev/null &
    @sleep 2
    @echo "🔌 Starting Holochain conductor..."
    @if [ ! -f "conductor-config.yaml" ]; then just _generate-conductor-config; fi
    @holochain -c conductor-config.yaml &>/dev/null &
    @sleep 3
    @echo "📊 Starting Observatory dashboard..."
    @if [ -f "observatory/package.json" ]; then cd observatory && pnpm dev &>/dev/null &; fi
    @sleep 2
    @echo ""
    @echo "✅ =================================="
    @echo "   MYCELIX IS READY!"
    @echo "✅ =================================="
    @echo ""
    @echo "📊 Observatory:     http://localhost:5173"
    @echo "🔌 Conductor Admin: ws://localhost:4444"
    @echo "🔌 Conductor App:   ws://localhost:4445"
    @echo ""
    @echo "Commands:"
    @echo "  just status    - Check ecosystem status"
    @echo "  just logs      - View live logs"
    @echo "  just stop      - Stop all services"
    @echo "  just test      - Run all tests"
    @echo ""

# Quick start for new developers (minimal)
quick-start:
    @echo ""
    @echo "🍄 MYCELIX QUICK START"
    @echo "======================"
    @echo ""
    @just _check-deps
    @echo "✓ Dependencies verified"
    @echo ""
    @echo "Building minimal hApps..."
    @just build-sdk 2>/dev/null || true
    @just build-production 2>/dev/null || true
    @echo ""
    @echo "Starting services..."
    @just up
    @echo ""
    @echo "📖 Next steps:"
    @echo "   1. Visit http://localhost:5173 (Observatory)"
    @echo "   2. Run 'just test' to verify everything works"
    @echo "   3. See 'just' for all available commands"
    @echo ""

# Full ecosystem: build everything then start
all: build up
    @echo "🍄 Full ecosystem is running!"

