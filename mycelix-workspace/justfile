# Start all services for local development
dev:
    @echo "🍄 Starting Mycelix development environment..."
    @just _check-deps
    just _start-lair &
    sleep 2
    just _start-conductor &
    sleep 3
    just _start-observatory &
    @echo ""
    @echo "✅ All services started!"
    @echo "   Observatory: http://localhost:5173"
    @echo "   Conductor Admin: localhost:4444"
    @echo "   Conductor App: localhost:4445"

# Stop all running services
stop:
    @echo "🛑 Stopping all services..."
    -pkill -f "lair-keystore" 2>/dev/null || true
    -pkill -f "holochain" 2>/dev/null || true
    -pkill -f "vite" 2>/dev/null || true
    @echo "✅ All services stopped"

# Restart all services
restart: stop dev

