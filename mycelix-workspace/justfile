                    echo "  [!!] $cluster -> $target (broken)"
                fi
            else
                echo "  [OK] $cluster (native)"
            fi
        else
            echo "  [--] $cluster (missing)"
        fi
    done
    echo ""
    echo "Standalone hApps:"
    echo ""
    echo "  Production Ready:"
    for happ in core epistemic-markets fabrication edunet marketplace; do
        if [ -d "happs/$happ" ]; then
            if [ -L "happs/$happ" ]; then
                target=$(readlink "happs/$happ")
                if [ -d "happs/$happ" ]; then
                    echo "    [OK] $happ -> $target"
                else
                    echo "    [!!] $happ -> $target (broken)"
                fi
            else
                echo "    [OK] $happ (native)"
            fi
        else
            echo "    [--] $happ (missing)"
        fi
    done
    echo ""
