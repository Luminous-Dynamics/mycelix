# ============================================================
# INTERNAL RECIPES (prefixed with _)
# ============================================================

_check-deps:
    @command -v holochain >/dev/null 2>&1 || { echo "❌ holochain not found. Run 'nix develop' first."; exit 1; }
    @command -v hc >/dev/null 2>&1 || { echo "❌ hc not found. Run 'nix develop' first."; exit 1; }

_start-lair:
    @echo "🔐 Starting Lair keystore..."
    @mkdir -p .lair
    lair-keystore server run --piped 2>&1 | while read line; do echo "[lair] $line"; done

_start-conductor:
    @echo "🔌 Starting Holochain conductor..."
    @if [ ! -f "conductor-config.yaml" ]; then just _generate-conductor-config; fi
    holochain -c conductor-config.yaml 2>&1 | while read line; do echo "[conductor] $line"; done

_start-observatory:
    @echo "📊 Starting Observatory dashboard..."
    @if [ -f "observatory/package.json" ]; then \
        cd observatory && pnpm dev 2>&1 | while read line; do echo "[observatory] $line"; done; \
    else \
        echo "⚠️  Observatory not set up yet"; \
    fi

_generate-conductor-config:
    @echo "📝 Generating conductor config..."
    @printf '%s\n' \
        '---' \
        'signing_service_uri: ~' \
        'encryption_service_uri: ~' \
        'decryption_service_uri: ~' \
        'dpki: ~' \
        'keystore:' \
        '  type: lair_server_in_proc' \
        'admin_interfaces:' \
        '  - driver:' \
        '      type: websocket' \
        '      port: 4444' \
        'network:' \
        '  bootstrap_service: https://bootstrap.holo.host' \
        '  transport_pool:' \
        '    - type: webrtc' \
        '      signal_url: wss://signal.holo.host' \
        > conductor-config.yaml

_check-hdk-versions:
    @echo ""
    @for dir in happs/*/dna/zomes/*/; do \
        if [ -f "$$dir/Cargo.toml" ]; then \
            echo "$$dir:"; \
            grep -E "^hdk|^hdi" "$$dir/Cargo.toml" 2>/dev/null || echo "  (no hdk/hdi found)"; \
            echo ""; \
        fi; \
    done

_migrate-cargo path:
    @echo "Updating Cargo.toml in {{path}}..."
    @find {{path}} -name "Cargo.toml" -exec sed -i \
        -e 's/hdk = "[0-9.]*"/hdk = "0.6.0"/' \
        -e 's/hdi = "[0-9.]*"/hdi = "0.7.0"/' \
        -e 's/holochain = "[0-9.]*"/holochain = "0.6.0"/' \
        {} \;

_migrate-package-json path:
    @echo "Updating package.json in {{path}}..."
    @if [ -f "{{path}}/package.json" ]; then \
        sed -i 's/"@holochain\/client": "[^"]*"/"@holochain\/client": "^0.20.0"/' {{path}}/package.json; \
        sed -i 's/"@holochain\/tryorama": "[^"]*"/"@holochain\/tryorama": "^0.19.0"/' {{path}}/package.json; \
    fi

_ensure-built:
    #!/usr/bin/env bash
    set -euo pipefail

    # Check if we have at least some builds
    sdk_built=false
    happs_built=false

    if [ -f "sdk/target/release/libmycelix_sdk.rlib" ] || [ -d "sdk/target/release" ]; then
        sdk_built=true
    fi

    # Count .happ files
    happ_count=$(find happs -name "*.happ" 2>/dev/null | wc -l)
    if [ "$happ_count" -gt 0 ]; then
        happs_built=true
    fi

    if [ "$sdk_built" = false ] || [ "$happs_built" = false ]; then
        echo "📦 First run detected - building minimal ecosystem..."
        echo ""

        if [ "$sdk_built" = false ]; then
            echo "Building SDK..."
            cd sdk && cargo build --release 2>/dev/null || true
            cd ..
        fi

        if [ "$happs_built" = false ]; then
            echo "Building production hApps..."
            just build-production 2>/dev/null || true
        fi

        echo ""
        echo "✓ Minimal build complete"
    fi

# Health check for all services
_health-check:
    #!/usr/bin/env bash
    echo ""
    echo "🏥 Health Check"
    echo "==============="

    # Check lair
    if pgrep -x "lair-keystore" > /dev/null; then
        echo "  [✓] Lair keystore running"
    else
        echo "  [✗] Lair keystore not running"
    fi

    # Check conductor
    if pgrep -x "holochain" > /dev/null; then
        echo "  [✓] Holochain conductor running"
    else
        echo "  [✗] Holochain conductor not running"
    fi

    # Check observatory
    if pgrep -f "vite" > /dev/null && [ -f "observatory/package.json" ]; then
        echo "  [✓] Observatory running"
    else
        echo "  [~] Observatory not running"
    fi

    echo ""

