conductor-stop:
    @./scripts/start-conductor.sh stop

# Check conductor status
conductor-status:
    @./scripts/start-conductor.sh status

# Install a hApp on the running conductor
conductor-install app_id happ_path:
    @echo "test-passphrase" | env PATH="/nix/store/iiccjs34fkg4ak9g8lh6wfag2s60i88a-lair-keystore-0.6.3/bin:$PATH" hc sandbox --piped call --running 4444 install-app --app-id {{app_id}} {{happ_path}}
    @echo "test-passphrase" | env PATH="/nix/store/iiccjs34fkg4ak9g8lh6wfag2s60i88a-lair-keystore-0.6.3/bin:$PATH" hc sandbox --piped call --running 4444 enable-app {{app_id}}

# List apps on the running conductor
conductor-list-apps:
    @echo "test-passphrase" | env PATH="/nix/store/iiccjs34fkg4ak9g8lh6wfag2s60i88a-lair-keystore-0.6.3/bin:$PATH" hc sandbox --piped call --running 4444 list-apps
