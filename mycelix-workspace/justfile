# Build the unified hApp bundle (all 7 DNAs + pack the hApp manifest)
build-unified-happ: build-all-dnas
    #!/usr/bin/env bash
    set -euo pipefail
    echo ""
    echo "📦 Packing Mycelix Unified hApp..."
    echo "==================================="

    # Verify symlinks exist in happs/
    HAPPS_DIR="/srv/luminous-dynamics/mycelix-workspace/happs"
    missing=0
    for role in personal identity hearth commons civic attribution; do
        if [ ! -L "$HAPPS_DIR/$role" ] && [ ! -d "$HAPPS_DIR/$role" ]; then
            echo "  ERROR: happs/$role symlink missing"
            echo "         Run: ln -sfn /srv/luminous-dynamics/mycelix-$role $HAPPS_DIR/$role"
            missing=$((missing + 1))
        fi
    done
    if [ "$missing" -gt 0 ]; then
        echo "Cannot pack unified hApp: $missing symlink(s) missing"
        exit 1
    fi

    # Verify all 7 DNA files exist
    DNAS=(
        "personal/dna/mycelix_personal.dna"
        "identity/dna/mycelix_identity_dna.dna"
        "hearth/dna/mycelix_hearth.dna"
        "commons/dna/mycelix_commons_land.dna"
        "commons/dna/mycelix_commons_care.dna"
        "civic/dna/mycelix_civic.dna"
        "attribution/dna/mycelix_attribution_dna.dna"
    )
    missing=0
    for dna in "${DNAS[@]}"; do
        if [ ! -f "$HAPPS_DIR/$dna" ]; then
            echo "  MISSING: $dna"
            missing=$((missing + 1))
        else
            size=$(stat -c%s "$HAPPS_DIR/$dna" 2>/dev/null || stat -f%z "$HAPPS_DIR/$dna")
            echo "  OK: $dna ($((size / 1024))K)"
        fi
    done
    if [ "$missing" -gt 0 ]; then
        echo "Cannot pack unified hApp: $missing DNA file(s) missing"
        exit 1
    fi

    # Pack the unified hApp
    cd "$HAPPS_DIR"
    hc app pack . -o mycelix-unified.happ --manifest-path mycelix-unified-happ.yaml
    echo ""
    echo "✅ Unified hApp packed: happs/mycelix-unified.happ"

