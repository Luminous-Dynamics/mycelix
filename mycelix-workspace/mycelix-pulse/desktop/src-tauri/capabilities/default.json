{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for the Mycelix Pulse desktop window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-set-focus",
    "core:window:allow-show",
    "core:webview:default",
    "core:webview:allow-set-webview-zoom",
    "dialog:default",
    "notification:default",
    "os:default",
    "process:default",
    "process:allow-exit",
    "fs:default",
    "shell:allow-open"
  ]
}
