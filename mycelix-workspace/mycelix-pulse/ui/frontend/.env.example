# API Configuration
# Rust backend (Axum) - default port 3001
VITE_API_URL=http://localhost:3001
VITE_WS_URL=ws://localhost:3001

# WebSocket endpoint: /ws/events
# REST API endpoints:
#   /api/auth/*     - Authentication
#   /api/emails/*   - Email operations
#   /api/trust/*    - Trust scoring
#   /api/did/*      - DID resolution (via DHT)
#   /health         - Health check

# Application Configuration
VITE_APP_NAME=Mycelix Mail
VITE_APP_VERSION=1.0.0

# Feature Flags
VITE_ENABLE_DEBUG=false
VITE_ENABLE_DRAFT_AUTOSAVE=true

# Performance
VITE_QUERY_STALE_TIME=30000
VITE_QUERY_CACHE_TIME=300000
