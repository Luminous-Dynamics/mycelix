# Mycelix Mail - Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# Core Settings
# =============================================================================

# Domain for the application
DOMAIN=mail.example.com

# Environment (development, staging, production)
ENVIRONMENT=production

# =============================================================================
# Database
# =============================================================================

# PostgreSQL password (generate with: openssl rand -base64 32)
DB_PASSWORD=change_me_to_secure_password

# =============================================================================
# Redis
# =============================================================================

# Redis password (generate with: openssl rand -base64 32)
REDIS_PASSWORD=change_me_to_secure_password

# =============================================================================
# Security
# =============================================================================

# JWT secret key (generate with: openssl rand -base64 64)
JWT_SECRET=change_me_to_very_long_secure_secret

# Encryption key for at-rest encryption (generate with: openssl rand -base64 32)
ENCRYPTION_KEY=change_me_to_secure_key

# =============================================================================
# Search
# =============================================================================

# Meilisearch master key (generate with: openssl rand -base64 32)
MEILISEARCH_KEY=change_me_to_secure_key

# =============================================================================
# Monitoring (Optional)
# =============================================================================

# Grafana admin password
GRAFANA_PASSWORD=change_me

# =============================================================================
# Email
# =============================================================================

# SMTP server for sending emails
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com

# =============================================================================
# AI/ML (Optional)
# =============================================================================

# Enable AI features
ENABLE_AI=false

# OpenAI API key (if using OpenAI instead of Ollama)
# OPENAI_API_KEY=

# =============================================================================
# Federation (Optional)
# =============================================================================

# Enable federation with other Mycelix instances
ENABLE_FEDERATION=false

# Instance public key (auto-generated if not provided)
# FEDERATION_PUBLIC_KEY=

# =============================================================================
# Backups
# =============================================================================

# S3-compatible storage for backups
# BACKUP_S3_ENDPOINT=
# BACKUP_S3_BUCKET=
# BACKUP_S3_ACCESS_KEY=
# BACKUP_S3_SECRET_KEY=
