{
  "name": "@mycelix/sdk",
  "version": "0.1.0",
  "description": "Official TypeScript/JavaScript SDK for Mycelix Mail - REST API and Holochain clients",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./holochain": {
      "import": "./dist/holochain/index.mjs",
      "require": "./dist/holochain/index.js",
      "types": "./dist/holochain/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/holochain/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts src/holochain/index.ts --format cjs,esm --dts --watch",
    "test": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "docs": "typedoc",
    "docs:watch": "typedoc --watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mycelix",
    "email",
    "mail",
    "api",
    "sdk",
    "trust",
    "web-of-trust",
    "decentralized"
  ],
  "author": "Mycelix Team",
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/mycelix/mycelix-mail"
  },
  "bugs": {
    "url": "https://github.com/mycelix/mycelix-mail/issues"
  },
  "homepage": "https://mycelix.mail/docs/sdk",
  "dependencies": {
    "@holochain/client": "^0.18.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "eslint": "^8.55.0",
    "react": "^18.2.0",
    "tsup": "^8.0.1",
    "typedoc": "^0.25.0",
    "typedoc-plugin-markdown": "^3.17.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
