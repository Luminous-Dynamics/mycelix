# Mycelix-Mail Backend Configuration
# Copy to .env and fill in values

# Server
HOST=0.0.0.0
PORT=3001

# =============================================================================
# Holochain Conductor Connection
# =============================================================================

# App WebSocket URL (for zome calls)
HOLOCHAIN_CONDUCTOR_URL=ws://localhost:8888

# Admin WebSocket URL (for authentication token issuance)
HOLOCHAIN_ADMIN_URL=ws://localhost:8889

# Installed app ID in the conductor
HOLOCHAIN_APP_ID=mycelix_mail

# Enable stub mode for testing without a real conductor (true/false)
# When enabled, the service returns mock data instead of connecting to conductor
HOLOCHAIN_STUB_MODE=false

# Connection timeout in seconds (default: 30)
HOLOCHAIN_CONNECT_TIMEOUT_SECS=30

# Maximum reconnection attempts before giving up (default: 5)
HOLOCHAIN_MAX_RECONNECT_ATTEMPTS=5

# =============================================================================
# Lair Keystore (Optional - for production with lair-keystore)
# =============================================================================

# Lair keystore connection URL (leave empty to use ClientAgentSigner)
# LAIR_URL=unix:///path/to/lair-keystore/socket

# Lair keystore passphrase (required if LAIR_URL is set)
# LAIR_PASSPHRASE=your-lair-passphrase

# =============================================================================
# JWT Authentication
# =============================================================================

# JWT secret key for token signing (REQUIRED - generate a secure secret)
# Generate with: openssl rand -base64 32
JWT_SECRET=your-secure-secret-here-change-this
JWT_EXPIRATION_HOURS=24

# =============================================================================
# Trust Score Caching
# =============================================================================

# Cache TTL in seconds (default: 300 = 5 minutes)
TRUST_CACHE_TTL_SECS=300

# Maximum cache entries (default: 10000)
TRUST_CACHE_MAX_ENTRIES=10000

# =============================================================================
# Spam Filtering
# =============================================================================

# Default minimum trust score for inbox filtering (0.0 - 1.0)
DEFAULT_MIN_TRUST=0.3

# Byzantine detection threshold (users below this are flagged)
BYZANTINE_THRESHOLD=0.2

# =============================================================================
# CORS Configuration
# =============================================================================

# Allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# =============================================================================
# Rate Limiting
# =============================================================================

# Requests per minute per IP
RATE_LIMIT_RPM=100

# =============================================================================
# Logging
# =============================================================================

# Log level: trace, debug, info, warn, error
LOG_LEVEL=info
