# Mycelix Music Web App - Environment Variables
# Copy this file to .env.local and fill in your values

# =============================================================================
# API Configuration
# =============================================================================
# Main API (songs, artists, playlists)
NEXT_PUBLIC_API_URL=http://localhost:3100

# Rust Core API (audio analysis, ML, transcoding, sessions)
NEXT_PUBLIC_RUST_API_URL=http://localhost:3000

# WebSocket URL for real-time communication
NEXT_PUBLIC_WS_URL=ws://localhost:3000/ws

# =============================================================================
# Blockchain Configuration
# =============================================================================
NEXT_PUBLIC_CHAIN_ID=31337
NEXT_PUBLIC_RPC_URL=http://localhost:8545

# Contract addresses (set after deployment)
NEXT_PUBLIC_ROUTER_ADDRESS=
NEXT_PUBLIC_FLOW_TOKEN_ADDRESS=

# =============================================================================
# Privy Configuration (Wallet Authentication)
# =============================================================================
# Get your App ID from https://dashboard.privy.io
NEXT_PUBLIC_PRIVY_APP_ID=

# =============================================================================
# Feature Flags
# =============================================================================
# NEXT_PUBLIC_ENABLE_TESTNET=true
