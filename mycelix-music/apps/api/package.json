{
  "name": "@mycelix/api",
  "version": "0.1.0",
  "license": "AGPL-3.0-or-later",

  "description": "Backend API for Mycelix Music platform",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "node ../../node_modules/eslint/bin/eslint.js src --ext .ts",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:ci": "jest --coverage --ci --reporters=default --reporters=jest-junit",
    "migrate": "tsx scripts/migrate.ts",
    "migrate:status": "tsx scripts/migrate.ts --status"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "pg": "^8.11.3",
    "redis": "^4.6.11",
    "@web3-storage/w3up-client": "^13.0.0",
    "@ceramicnetwork/http-client": "^3.0.0",
    "ethers": "^6.9.0",
    "socket.io": "^4.7.0",
    "@sentry/node": "^8.0.0",
    "@opentelemetry/api": "^1.7.0",
    "@opentelemetry/sdk-node": "^0.48.0",
    "@opentelemetry/auto-instrumentations-node": "^0.43.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.48.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.48.0",
    "@opentelemetry/resources": "^1.21.0",
    "@opentelemetry/semantic-conventions": "^1.21.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/pg": "^8.10.9",
    "@types/supertest": "^6.0.0",
    "@types/node-fetch": "^2.6.0",
    "supertest": "^6.3.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.0",
    "prom-client": "^15.0.0",
    "typescript": "^5.3.0",
    "tsx": "^4.7.0"
  }
}
