{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mycelix.org/edunet/EduAchievementCredential.schema.json",
  "title": "EduAchievementCredential",
  "description": "Verifiable Credential for educational achievements in EduNet",
  "type": "object",
  "properties": {
    "@context": {
      "description": "JSON-LD context",
      "oneOf": [
        { "type": "array" },
        { "type": "string" }
      ]
    },
    "type": {
      "description": "Credential type",
      "type": "array",
      "contains": {
        "const": "VerifiableCredential"
      },
      "items": {
        "type": "string"
      }
    },
    "issuer": {
      "description": "Issuer identifier (DID or agent public key)",
      "type": "string"
    },
    "issuanceDate": {
      "description": "Issuance date (ISO 8601)",
      "type": "string",
      "format": "date-time"
    },
    "expirationDate": {
      "description": "Optional expiration date (ISO 8601)",
      "type": "string",
      "format": "date-time"
    },
    "credentialSubject": {
      "type": "object",
      "properties": {
        "id": {
          "description": "Learner identifier (DID or agent public key)",
          "type": "string"
        },
        "courseId": {
          "description": "Course identifier",
          "type": "string"
        },
        "modelId": {
          "description": "Model ID for provenance tracking",
          "type": "string"
        },
        "rubricId": {
          "description": "Assessment rubric identifier",
          "type": "string"
        },
        "score": {
          "description": "Numerical score",
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "scoreBand": {
          "description": "Score band (e.g., A, B, C, Pass, Mastery)",
          "type": "string"
        },
        "completionDate": {
          "description": "Course completion date",
          "type": "string",
          "format": "date-time"
        },
        "skills": {
          "description": "Skills or competencies demonstrated",
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": ["id", "courseId", "modelId", "rubricId"]
    },
    "credentialStatus": {
      "description": "Credential status for revocation checking",
      "type": "object",
      "properties": {
        "id": {
          "description": "Status list identifier",
          "type": "string"
        },
        "type": {
          "description": "Status method type",
          "const": "StatusList2021Entry"
        },
        "statusListIndex": {
          "description": "Index in status list",
          "type": "integer",
          "minimum": 0
        },
        "statusPurpose": {
          "description": "Purpose (revocation, suspension, etc.)",
          "type": "string",
          "enum": ["revocation", "suspension"]
        }
      },
      "required": ["id", "type"]
    },
    "proof": {
      "description": "Cryptographic proof",
      "type": "object",
      "properties": {
        "type": {
          "description": "Proof type",
          "type": "string"
        },
        "created": {
          "description": "Proof creation timestamp",
          "type": "string",
          "format": "date-time"
        },
        "verificationMethod": {
          "description": "Public key reference",
          "type": "string"
        },
        "proofPurpose": {
          "description": "Proof purpose",
          "type": "string"
        },
        "proofValue": {
          "description": "Signature value (base64)",
          "type": "string"
        }
      },
      "required": ["type", "created", "verificationMethod", "proofPurpose", "proofValue"]
    }
  },
  "required": ["@context", "type", "issuer", "issuanceDate", "credentialSubject", "proof"]
}
