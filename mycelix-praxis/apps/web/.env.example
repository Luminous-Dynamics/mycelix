# EduNet Web Application - Environment Variables
# Copy this file to .env and update with your values

# ==================== API Configuration ====================
# Base URL for the EduNet API
VITE_API_URL=http://localhost:3000

# ==================== Feature Flags ====================
# Enable Holochain integration (default: false)
VITE_ENABLE_HOLOCHAIN=false

# Enable mock data for development (default: true)
VITE_ENABLE_MOCK_DATA=true

# Enable error simulation for testing (default: true)
VITE_ENABLE_ERROR_SIMULATION=true

# Enable analytics tracking (default: false)
VITE_ENABLE_ANALYTICS=false

# ==================== Holochain Configuration ====================
# Use real Holochain client instead of mock (default: false)
# When true, connects to a running Holochain conductor
VITE_USE_REAL_CLIENT=false

# Use mock client for development (default: true)
# When true, uses in-memory mock data without Holochain
VITE_USE_MOCK_CLIENT=true

# Holochain WebSocket URL for app interface
# The conductor must be running and listening on this URL
# Note: Admin interface is on 8888, App interface is on 8889
VITE_APP_WS_URL=ws://localhost:8889

# Installed App ID in the conductor
# Must match the app ID when installing the DNA
VITE_APP_ID=mycelix-edunet

# Role name within the app
# Typically matches the DNA name
VITE_ROLE_NAME=edunet

# Enable verbose Holochain client logs (default: false)
VITE_VERBOSE_LOGS=false

# Auto-reconnect on WebSocket disconnect (default: true)
VITE_AUTO_RECONNECT=true

# ==================== Development Settings ====================
# Enable debug mode (shows additional logging)
VITE_DEBUG_MODE=false

# Enable performance monitoring
VITE_PERFORMANCE_MONITORING=false

# ==================== External Services ====================
# Analytics service key (e.g., Google Analytics, Plausible)
VITE_ANALYTICS_KEY=

# Error tracking service (e.g., Sentry DSN)
VITE_SENTRY_DSN=

# ==================== Optional Overrides ====================
# Override default toast duration (milliseconds)
# VITE_TOAST_DURATION=5000

# Override default API timeout (milliseconds)
# VITE_API_TIMEOUT=30000

# Override max retry attempts for failed requests
# VITE_MAX_RETRY_ATTEMPTS=3
