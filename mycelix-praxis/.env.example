# Mycelix EduNet Environment Configuration
# Copy this file to .env and customize for your environment

# ============================================================================
# Application Configuration
# ============================================================================

# Environment (development, staging, production)
NODE_ENV=development

# Application ports
WEB_PORT=3000
CONDUCTOR_ADMIN_PORT=4444
CONDUCTOR_APP_PORT=8888

# ============================================================================
# Holochain Configuration (v0.2.0+)
# ============================================================================

# Conductor log level (trace, debug, info, warn, error)
RUST_LOG=info

# Lair keystore configuration
# LAIR_CONNECTION_URL=unix:///data/lair/socket

# ============================================================================
# Security
# ============================================================================

# Admin API password (change in production!)
# ADMIN_PASSWORD=change_me_in_production

# CORS allowed origins (comma-separated)
# CORS_ALLOWED_ORIGINS=http://localhost:3000,https://edunet.example.com

# ============================================================================
# Deployment
# ============================================================================

# Public URL for the application
# PUBLIC_URL=https://edunet.example.com

# TLS/SSL configuration (if using reverse proxy)
# TLS_CERT_PATH=/etc/letsencrypt/live/edunet.example.com/fullchain.pem
# TLS_KEY_PATH=/etc/letsencrypt/live/edunet.example.com/privkey.pem

# ============================================================================
# Monitoring & Logging
# ============================================================================

# Sentry DSN for error tracking (optional)
# SENTRY_DSN=

# Log retention (days)
LOG_RETENTION_DAYS=7

# ============================================================================
# Development
# ============================================================================

# Enable hot reload (development only)
VITE_HMR=true

# API mock mode (use mock data instead of real conductor)
VITE_MOCK_MODE=true

# ============================================================================
# Notes
# ============================================================================

# - Never commit .env to version control
# - Use strong passwords in production
# - Keep this file in sync with .env.example
# - Restart services after changing environment variables
