# TrustML Phase 9 - Environment Configuration Template
# Copy this file to .env and fill in your values

# ============================================
# Database Configuration
# ============================================
TRUSTML_DB_PASSWORD=changeme_in_production
# Use a strong password generator: openssl rand -base64 32

# ============================================
# Node Configuration
# ============================================
TRUSTML_NODE_ID=fl-node-001
# Unique identifier for this node

# ============================================
# Monitoring Configuration
# ============================================
GRAFANA_USER=admin
GRAFANA_PASSWORD=changeme_in_production
# Access Grafana at http://localhost:3000

# ============================================
# Logging Configuration
# ============================================
TRUSTML_LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL

# ============================================
# Byzantine Detection Tuning (Optional)
# ============================================
# TRUSTML_POGQ_THRESHOLD=0.35
# TRUSTML_REPUTATION_DECAY=0.95
# TRUSTML_ANOMALY_SENSITIVITY=2.5

# ============================================
# Network Configuration (Optional)
# ============================================
# TRUSTML_LISTEN_PORT=8765
# TRUSTML_PROMETHEUS_PORT=9090

# ============================================
# Security (Production Only)
# ============================================
# TRUSTML_REQUIRE_SIGNATURES=true
# TRUSTML_ENCRYPT_GRADIENTS=true
# TRUSTML_RATE_LIMIT=60  # requests per minute
