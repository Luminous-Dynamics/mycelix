{
  "dashboard": {
    "title": "ZeroTrustML Network Performance",
    "tags": ["zerotrustml", "network", "performance"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "Active Connections",
        "type": "stat",
        "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4},
        "targets": [
          {
            "expr": "zerotrustml_active_connections",
            "legendFormat": "Connections"
          }
        ]
      },
      {
        "id": 2,
        "title": "Network Latency (p50, p95, p99)",
        "type": "graph",
        "gridPos": {"x": 0, "y": 4, "w": 12, "h": 6},
        "targets": [
          {
            "expr": "histogram_quantile(0.50, rate(zerotrustml_network_latency_seconds_bucket[5m]))",
            "legendFormat": "p50"
          },
          {
            "expr": "histogram_quantile(0.95, rate(zerotrustml_network_latency_seconds_bucket[5m]))",
            "legendFormat": "p95"
          },
          {
            "expr": "histogram_quantile(0.99, rate(zerotrustml_network_latency_seconds_bucket[5m]))",
            "legendFormat": "p99"
          }
        ],
        "yaxes": [
          {"format": "s", "label": "Latency"},
          {"format": "short"}
        ]
      },
      {
        "id": 3,
        "title": "Messages Sent/Received",
        "type": "graph",
        "gridPos": {"x": 0, "y": 10, "w": 12, "h": 6},
        "targets": [
          {
            "expr": "sum by (message_type) (rate(zerotrustml_messages_sent_total[5m]))",
            "legendFormat": "Sent: {{message_type}}"
          },
          {
            "expr": "sum by (message_type) (rate(zerotrustml_messages_received_total[5m]))",
            "legendFormat": "Received: {{message_type}}"
          }
        ]
      },
      {
        "id": 4,
        "title": "Message Rate by Type",
        "type": "piechart",
        "gridPos": {"x": 12, "y": 0, "w": 6, "h": 8},
        "targets": [
          {
            "expr": "sum by (message_type) (rate(zerotrustml_messages_sent_total[5m]))",
            "legendFormat": "{{message_type}}"
          }
        ]
      },
      {
        "id": 5,
        "title": "Network Latency Heatmap",
        "type": "heatmap",
        "gridPos": {"x": 0, "y": 16, "w": 12, "h": 6},
        "targets": [
          {
            "expr": "sum(rate(zerotrustml_network_latency_seconds_bucket[1m])) by (le)",
            "format": "heatmap",
            "legendFormat": "{{le}}"
          }
        ]
      }
    ],
    "refresh": "5s",
    "schemaVersion": 27,
    "version": 1
  }
}