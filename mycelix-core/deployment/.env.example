# =============================================================================
# MYCELIX TESTNET VALIDATOR CONFIGURATION
# =============================================================================
#
# Copy this file to .env and customize for your deployment:
#   cp .env.example .env
#
# IMPORTANT: Never commit your .env file to version control!
#
# Documentation: See OPERATOR_SETUP_GUIDE.md for detailed instructions.
# =============================================================================

# =============================================================================
# NODE IDENTITY
# =============================================================================

# Unique identifier for this validator node (required)
# Format: alphanumeric with hyphens, e.g., "validator-us-east-001"
VALIDATOR_NODE_ID=validator-001

# Geographic region for peer selection optimization
# Options: global, na, eu, asia, oceania, sa, africa
VALIDATOR_REGION=global

# Operator identifier for network statistics
# Your organization or username
VALIDATOR_OPERATOR=community

# Human-readable hostname for this node
VALIDATOR_HOSTNAME=mycelix-validator

# =============================================================================
# NETWORK CONFIGURATION
# =============================================================================

# Network type (testnet or mainnet)
# WARNING: mainnet is not yet available
NETWORK_TYPE=testnet

# Primary bootstrap server URL
# These are tried in order; fallbacks are configured in bootstrap_config.yaml
BOOTSTRAP_URL=https://bootstrap.mycelix.net

# WebRTC signaling server URL
SIGNAL_URL=wss://signal.holo.host

# =============================================================================
# FL COORDINATOR SETTINGS
# =============================================================================

# Minimum nodes required to complete an FL round
# Lower values allow operation with fewer peers but reduce security
FL_MIN_NODES=3

# Maximum nodes that can participate in a single round
# Higher values increase security but also latency
FL_MAX_NODES=100

# Timeout for FL round completion (seconds)
# Increase if your network has high latency
FL_ROUND_TIMEOUT_SECONDS=120

# Byzantine fault tolerance threshold
# Our breakthrough: 45% tolerance vs classical 33%
# DO NOT CHANGE unless you understand the implications
FL_BYZANTINE_THRESHOLD=0.45

# =============================================================================
# 0TML DETECTION SETTINGS
# =============================================================================

# Hypervector dimension for HyperFeel encoding
# Options: 1024 (compact), 2048 (standard), 4096 (high-fidelity)
MYCELIX_HV_DIMENSION=2048

# Byzantine detection threshold
# Must match FL_BYZANTINE_THRESHOLD
MYCELIX_BYZANTINE_THRESHOLD=0.45

# Use Rust backend for performance-critical operations
# Recommended: true
MYCELIX_USE_RUST=true

# Enable debug mode (verbose logging)
# WARNING: Increases log volume significantly
MYCELIX_DEBUG=false

# =============================================================================
# HOLOCHAIN CONDUCTOR
# =============================================================================

# Admin WebSocket port for conductor management
HC_ADMIN_PORT=39329

# Application WebSocket port for hApp communication
HC_APP_PORT=9998

# Path to Holochain data directory
HC_DATA_PATH=/data/holochain

# =============================================================================
# METRICS & MONITORING
# =============================================================================

# Enable Prometheus metrics endpoint
METRICS_ENABLED=true

# Port for Prometheus metrics scraping
METRICS_PORT=9090

# Port for health check endpoint
HEALTH_CHECK_PORT=8080

# Prometheus external port (host binding)
PROMETHEUS_PORT=9091

# Grafana external port (host binding)
GRAFANA_PORT=3000

# Grafana admin credentials
# CHANGE THESE IN PRODUCTION!
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=mycelix-admin

# Grafana external URL (for proper linking)
GRAFANA_ROOT_URL=http://localhost:3000

# =============================================================================
# LOGGING
# =============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log format: json (structured) or text (human-readable)
LOG_FORMAT=json

# Rust log level for Holochain components
RUST_LOG=info

# =============================================================================
# RESOURCE LIMITS
# =============================================================================

# Maximum memory usage in MB
MAX_MEMORY_MB=4096

# Maximum worker threads for parallel processing
MAX_WORKERS=4

# Docker CPU limit (number of CPUs)
CPU_LIMIT=4

# Docker memory limit
MEMORY_LIMIT=4G

# Docker CPU reservation (guaranteed)
CPU_RESERVATION=1

# Docker memory reservation (guaranteed)
MEMORY_RESERVATION=1G

# =============================================================================
# DATA PATHS
# =============================================================================

# Base path for all persistent data
# This directory must exist and be writable
DATA_PATH=./data

# =============================================================================
# OPTIONAL: ALERTING
# =============================================================================

# AlertManager port (if using alerting profile)
ALERTMANAGER_PORT=9093

# Node Exporter port (if using monitoring profile)
NODE_EXPORTER_PORT=9100

# =============================================================================
# OPTIONAL: GRPC
# =============================================================================

# FL Coordinator gRPC port (for advanced integrations)
FL_GRPC_PORT=50051

# =============================================================================
# LABEL SKEW OPTIMIZATION (ADVANCED)
# =============================================================================
# These values are CRITICAL for detection accuracy.
# See .env.optimal for details. DO NOT CHANGE unless you understand BFT.

# Behavior recovery threshold (strikes before reputation recovery)
BEHAVIOR_RECOVERY_THRESHOLD=2

# Behavior recovery bonus (reputation recovery rate)
BEHAVIOR_RECOVERY_BONUS=0.12

# Label skew cosine similarity bounds
# WARNING: -0.5 achieves 3.55% FP, -0.3 causes 57% FP (16x worse!)
LABEL_SKEW_COS_MIN=-0.5
LABEL_SKEW_COS_MAX=0.95
