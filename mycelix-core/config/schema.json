{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mycelix.net/config/schema.json",
  "title": "Mycelix Core Configuration Schema",
  "description": "Unified configuration schema for Mycelix Byzantine-resistant Federated Learning system",
  "type": "object",
  "properties": {
    "byzantine_detection": {
      "type": "object",
      "description": "Critical Byzantine fault tolerance parameters",
      "properties": {
        "label_skew_cos_min": {
          "type": "number",
          "default": -0.5,
          "minimum": -1.0,
          "maximum": 0.0,
          "description": "Minimum cosine similarity threshold for label skew detection. CRITICAL: Must be -0.5, NOT -0.3. Using -0.3 causes 16x performance degradation (57-92% FP vs 3.55-7.1% FP).",
          "performance_impact": "critical",
          "security_implications": "Incorrect value causes massive false positive rates, flagging honest nodes as Byzantine",
          "$comment": "WARNING: This is the most sensitive parameter in the system"
        },
        "label_skew_cos_max": {
          "type": "number",
          "default": 0.95,
          "minimum": 0.5,
          "maximum": 1.0,
          "description": "Maximum cosine similarity threshold. Detects overly-aligned attacks.",
          "performance_impact": "high",
          "security_implications": "Too high allows colluding Byzantine nodes to pass undetected"
        },
        "behavior_recovery_threshold": {
          "type": "integer",
          "default": 2,
          "minimum": 1,
          "maximum": 10,
          "description": "Number of consecutive good rounds before reputation recovery begins. CRITICAL: Must be 2, not 3+.",
          "performance_impact": "high",
          "security_implications": "Higher values slow honest node recovery; lower values may allow Byzantine nodes to recover too quickly",
          "$comment": "Validated optimal: 2 for CIFAR-10 and Breast Cancer, 3 for EMNIST"
        },
        "behavior_recovery_bonus": {
          "type": "number",
          "default": 0.12,
          "minimum": 0.01,
          "maximum": 0.5,
          "description": "Reputation bonus per good round after recovery threshold met. CRITICAL: Must be 0.12, not 0.10.",
          "performance_impact": "high",
          "security_implications": "Too low causes permanent honest node exclusion; too high allows Byzantine rehabilitation"
        },
        "reputation_floor": {
          "type": "number",
          "default": 0.01,
          "minimum": 0.0,
          "maximum": 0.5,
          "description": "Minimum reputation value to prevent permanent exclusion",
          "performance_impact": "medium",
          "security_implications": "Zero floor permanently excludes nodes; high floor allows Byzantine persistence"
        },
        "reputation_decay": {
          "type": "number",
          "default": 0.95,
          "minimum": 0.5,
          "maximum": 1.0,
          "description": "Decay factor applied to reputation each round",
          "performance_impact": "medium",
          "security_implications": "Low decay quickly forgets Byzantine behavior"
        },
        "reputation_initial": {
          "type": "number",
          "default": 0.5,
          "minimum": 0.0,
          "maximum": 1.0,
          "description": "Starting reputation for new nodes",
          "performance_impact": "low",
          "security_implications": "High initial reputation gives new Byzantine nodes more influence"
        },
        "pogq_threshold": {
          "type": "number",
          "default": 0.7,
          "minimum": 0.0,
          "maximum": 1.0,
          "description": "Proof of Gradient Quality minimum threshold for acceptance",
          "performance_impact": "high",
          "security_implications": "Low threshold accepts poor gradients; high threshold may reject honest nodes"
        },
        "pogq_test_size": {
          "type": "number",
          "default": 0.1,
          "minimum": 0.01,
          "maximum": 0.5,
          "description": "Fraction of data used for PoGQ validation",
          "performance_impact": "medium",
          "security_implications": "Larger test set provides better validation but reduces training data"
        },
        "committee_reject_floor": {
          "type": "number",
          "default": 0.25,
          "minimum": 0.0,
          "maximum": 1.0,
          "description": "Minimum committee rejection rate to flag a node. Use 0.1 for label_skew distribution.",
          "performance_impact": "medium",
          "security_implications": "Low floor increases false positives; high floor may miss Byzantine nodes"
        },
        "anomaly_sensitivity": {
          "type": "number",
          "default": 2.5,
          "minimum": 1.0,
          "maximum": 5.0,
          "description": "Standard deviations for anomaly detection",
          "performance_impact": "medium",
          "security_implications": "Low sensitivity causes false positives; high sensitivity may miss attacks"
        },
        "anomaly_window_size": {
          "type": "integer",
          "default": 10,
          "minimum": 3,
          "maximum": 100,
          "description": "Number of rounds to analyze for anomaly detection",
          "performance_impact": "low",
          "security_implications": "Larger window provides more stable detection but slower response"
        },
        "byzantine_penalty": {
          "type": "number",
          "default": -0.2,
          "minimum": -1.0,
          "maximum": 0.0,
          "description": "Reputation penalty for detected Byzantine behavior",
          "performance_impact": "medium",
          "security_implications": "Stronger penalty provides faster exclusion but increases false positive impact"
        },
        "false_positive_threshold": {
          "type": "number",
          "default": 0.01,
          "minimum": 0.0,
          "maximum": 0.1,
          "description": "Target false positive rate tolerance",
          "performance_impact": "low",
          "security_implications": "Higher threshold accepts more risk of honest node exclusion"
        },
        "zero_norm_threshold": {
          "type": "number",
          "default": 1e-6,
          "description": "Threshold for detecting zero-gradient attacks",
          "performance_impact": "low",
          "security_implications": "Detects nodes sending empty or near-zero gradients"
        },
        "backdoor_spike_threshold": {
          "type": "number",
          "default": 3.0,
          "minimum": 1.0,
          "maximum": 10.0,
          "description": "Threshold for detecting backdoor attacks via gradient spikes",
          "performance_impact": "medium",
          "security_implications": "Lower values catch more attacks but may trigger on legitimate high-magnitude gradients"
        },
        "hybrid_suspicion_threshold": {
          "type": "number",
          "default": 0.35,
          "minimum": 0.0,
          "maximum": 1.0,
          "description": "Combined suspicion score threshold for hybrid detection",
          "performance_impact": "high",
          "security_implications": "Primary threshold for final Byzantine classification"
        },
        "hybrid_weights": {
          "type": "object",
          "description": "Weights for hybrid detection components (must sum to 1.0)",
          "properties": {
            "pogq": {"type": "number", "default": 0.35},
            "cosine": {"type": "number", "default": 0.30},
            "committee": {"type": "number", "default": 0.15},
            "norm": {"type": "number", "default": 0.10},
            "cluster": {"type": "number", "default": 0.10}
          }
        }
      },
      "required": ["label_skew_cos_min", "behavior_recovery_threshold", "behavior_recovery_bonus"]
    },
    "dataset_specific": {
      "type": "object",
      "description": "Dataset-specific parameter overrides. Different datasets require different thresholds due to varying gradient statistics.",
      "properties": {
        "cifar10": {
          "type": "object",
          "description": "CIFAR-10: High-dimensional CNN (32x32x3 RGB images, ~3K+ params). Validated 77% success rate.",
          "properties": {
            "behavior_recovery_threshold": {"type": "integer", "default": 2},
            "behavior_recovery_bonus": {"type": "number", "default": 0.12},
            "label_skew_cos_min": {"type": "number", "default": -0.5},
            "label_skew_cos_max": {"type": "number", "default": 0.95},
            "committee_reject_floor": {"type": "number", "default": 0.25}
          }
        },
        "emnist_balanced": {
          "type": "object",
          "description": "EMNIST: Mid-dimensional CNN (28x28 grayscale, ~800+ params). 74% success, needs tighter IID thresholds.",
          "properties": {
            "behavior_recovery_threshold": {"type": "integer", "default": 3},
            "behavior_recovery_bonus": {"type": "number", "default": 0.10},
            "label_skew_cos_min": {"type": "number", "default": -0.4},
            "label_skew_cos_max": {"type": "number", "default": 0.96},
            "committee_reject_floor": {"type": "number", "default": 0.30}
          }
        },
        "breast_cancer": {
          "type": "object",
          "description": "Breast Cancer: Low-dimensional tabular MLP (30 features). CRITICAL: Uses CIFAR-10 cosine thresholds after parameter sweep validation.",
          "properties": {
            "behavior_recovery_threshold": {"type": "integer", "default": 2},
            "behavior_recovery_bonus": {"type": "number", "default": 0.12},
            "label_skew_cos_min": {"type": "number", "default": -0.5},
            "label_skew_cos_max": {"type": "number", "default": 0.95},
            "committee_reject_floor": {"type": "number", "default": 0.25}
          }
        }
      }
    },
    "federated_learning": {
      "type": "object",
      "description": "Federated learning training configuration",
      "properties": {
        "aggregation": {
          "type": "string",
          "enum": ["krum", "median", "trimmed_mean", "fedavg", "weighted"],
          "default": "krum",
          "description": "Gradient aggregation method. 'krum' and 'median' are Byzantine-robust.",
          "security_implications": "'fedavg' is NOT Byzantine-robust; use only for baselines"
        },
        "num_rounds": {
          "type": "integer",
          "default": 100,
          "minimum": 1,
          "maximum": 10000,
          "description": "Total training rounds",
          "performance_impact": "high"
        },
        "num_clients": {
          "type": "integer",
          "default": 10,
          "minimum": 2,
          "maximum": 1000,
          "description": "Total number of FL clients"
        },
        "clients_per_round": {
          "type": "integer",
          "default": 5,
          "minimum": 1,
          "description": "Clients participating per round. Must be <= num_clients."
        },
        "min_clients": {
          "type": "integer",
          "default": 5,
          "minimum": 2,
          "description": "Minimum clients required to proceed with aggregation"
        },
        "local_epochs": {
          "type": "integer",
          "default": 10,
          "minimum": 1,
          "maximum": 100,
          "description": "Local training epochs per client per round",
          "performance_impact": "high"
        },
        "learning_rate": {
          "type": "number",
          "default": 0.05,
          "minimum": 0.0001,
          "maximum": 1.0,
          "description": "Client learning rate"
        },
        "momentum": {
          "type": "number",
          "default": 0.9,
          "minimum": 0.0,
          "maximum": 0.99
        },
        "weight_decay": {
          "type": "number",
          "default": 0.0001,
          "minimum": 0.0,
          "maximum": 0.1
        },
        "gradient_clipping": {
          "type": "number",
          "default": 10.0,
          "minimum": 0.1,
          "maximum": 100.0,
          "description": "Maximum gradient norm for clipping",
          "security_implications": "Limits impact of Byzantine gradient attacks"
        },
        "data_distribution": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "enum": ["iid", "dirichlet", "label_skew"],
              "default": "dirichlet",
              "description": "Data distribution type across clients"
            },
            "alpha": {
              "type": "number",
              "default": 1.0,
              "minimum": 0.01,
              "maximum": 100.0,
              "description": "Dirichlet alpha for non-IID distribution. Lower = more heterogeneous."
            }
          }
        }
      }
    },
    "model": {
      "type": "object",
      "description": "Model architecture configuration",
      "properties": {
        "architecture": {
          "type": "string",
          "enum": ["EnhancedCNN", "simple_cnn", "resnet9", "EfficientNet-B0"],
          "default": "EnhancedCNN",
          "description": "Neural network architecture"
        },
        "normalization": {
          "type": "string",
          "enum": ["GroupNorm", "BatchNorm", "LayerNorm"],
          "default": "GroupNorm",
          "description": "Normalization layer type. GroupNorm recommended for FL (BatchNorm issues with small batches).",
          "performance_impact": "medium"
        },
        "dropout": {
          "type": "number",
          "default": 0.25,
          "minimum": 0.0,
          "maximum": 0.8
        },
        "fc_dropout": {
          "type": "number",
          "default": 0.5,
          "minimum": 0.0,
          "maximum": 0.8
        }
      }
    },
    "dataset": {
      "type": "object",
      "description": "Dataset configuration",
      "properties": {
        "name": {
          "type": "string",
          "enum": ["CIFAR10", "EMNIST", "MNIST", "breast_cancer"],
          "default": "CIFAR10"
        },
        "data_dir": {
          "type": "string",
          "default": "./data"
        },
        "batch_size": {
          "type": "integer",
          "default": 32,
          "minimum": 1,
          "maximum": 1024
        }
      }
    },
    "communication": {
      "type": "object",
      "description": "Communication efficiency settings",
      "properties": {
        "quantization": {
          "type": "object",
          "properties": {
            "enabled": {"type": "boolean", "default": true},
            "bits": {
              "type": "integer",
              "default": 8,
              "enum": [4, 8, 16],
              "description": "Quantization bit depth. 8-bit provides 4x compression."
            },
            "dynamic": {
              "type": "boolean",
              "default": true,
              "description": "Use dynamic range per layer"
            }
          }
        },
        "sparsification": {
          "type": "object",
          "properties": {
            "enabled": {"type": "boolean", "default": true},
            "sparsity": {
              "type": "number",
              "default": 0.9,
              "minimum": 0.0,
              "maximum": 0.99,
              "description": "Fraction of gradients to drop. 0.9 = keep top 10%."
            },
            "strategy": {
              "type": "string",
              "enum": ["topk", "random", "threshold"],
              "default": "topk"
            },
            "error_feedback": {
              "type": "boolean",
              "default": true,
              "description": "Accumulate dropped gradients for next round"
            }
          }
        }
      }
    },
    "fedprox": {
      "type": "object",
      "description": "FedProx proximal regularization settings",
      "properties": {
        "enabled": {"type": "boolean", "default": true},
        "mu": {
          "type": "number",
          "default": 0.01,
          "minimum": 0.0,
          "maximum": 1.0,
          "description": "Proximal term weight"
        },
        "adaptive_mu": {
          "type": "boolean",
          "default": true,
          "description": "Adjust mu based on client drift"
        },
        "drift_threshold": {"type": "number", "default": 0.5},
        "mu_max": {"type": "number", "default": 1.0},
        "mu_min": {"type": "number", "default": 0.001}
      }
    },
    "holochain": {
      "type": "object",
      "description": "Holochain DHT integration settings",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable Holochain DHT for immutable audit logs"
        },
        "conductor_url": {
          "type": "string",
          "default": "ws://localhost:8888",
          "format": "uri"
        },
        "admin_port": {
          "type": "integer",
          "default": 8888,
          "minimum": 1024,
          "maximum": 65535
        },
        "app_port": {
          "type": "integer",
          "default": 8889,
          "minimum": 1024,
          "maximum": 65535
        },
        "dna_path": {
          "type": "string",
          "default": "./holochain/dna/zerotrustml.dna"
        },
        "network": {
          "type": "object",
          "properties": {
            "bootstrap_url": {
              "type": "string",
              "default": "https://bootstrap-staging.holo.host"
            },
            "signal_url": {
              "type": "string",
              "default": "wss://signal.holo.host"
            },
            "gossip_loop_iteration_delay_ms": {
              "type": "integer",
              "default": 1000,
              "minimum": 100,
              "maximum": 60000
            },
            "default_notify_remote_agent_count": {
              "type": "integer",
              "default": 5
            },
            "default_notify_timeout_ms": {
              "type": "integer",
              "default": 10000
            },
            "agent_info_expires_after_ms": {
              "type": "integer",
              "default": 1200000
            }
          }
        }
      }
    },
    "credits": {
      "type": "object",
      "description": "Credit and reward system configuration",
      "properties": {
        "backend": {
          "type": "string",
          "enum": ["postgresql", "holochain", "hybrid"],
          "default": "postgresql"
        },
        "postgresql": {
          "type": "object",
          "properties": {
            "host": {"type": "string", "default": "localhost"},
            "port": {"type": "integer", "default": 5432},
            "database": {"type": "string", "default": "zerotrustml"},
            "min_connections": {"type": "integer", "default": 5},
            "max_connections": {"type": "integer", "default": 20}
          }
        },
        "rewards": {
          "type": "object",
          "properties": {
            "quality_credit_base": {"type": "integer", "default": 10},
            "quality_credit_multiplier": {"type": "number", "default": 1.5},
            "security_credit_detection": {"type": "integer", "default": 50},
            "security_credit_report": {"type": "integer", "default": 25},
            "validation_credit": {"type": "integer", "default": 5},
            "contribution_credit": {"type": "integer", "default": 1}
          }
        }
      }
    },
    "security": {
      "type": "object",
      "description": "Security settings",
      "properties": {
        "require_signatures": {
          "type": "boolean",
          "default": true,
          "description": "Require cryptographic signatures on all messages",
          "security_implications": "Disabling allows message spoofing"
        },
        "signature_algorithm": {
          "type": "string",
          "enum": ["ed25519", "secp256k1"],
          "default": "ed25519"
        },
        "encrypt_gradients": {
          "type": "boolean",
          "default": true,
          "description": "Encrypt gradients in transit",
          "security_implications": "Disabling exposes model updates to eavesdropping"
        },
        "encryption_algorithm": {
          "type": "string",
          "enum": ["chacha20-poly1305", "aes-256-gcm"],
          "default": "chacha20-poly1305"
        },
        "rate_limiting": {
          "type": "object",
          "properties": {
            "max_requests_per_minute": {"type": "integer", "default": 60},
            "max_requests_per_hour": {"type": "integer", "default": 1000}
          }
        },
        "tls_enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable TLS for network connections"
        }
      }
    },
    "privacy": {
      "type": "object",
      "description": "Privacy-preserving features",
      "properties": {
        "differential_privacy": {
          "type": "object",
          "properties": {
            "enabled": {"type": "boolean", "default": false},
            "epsilon": {
              "type": "number",
              "default": 1.0,
              "minimum": 0.01,
              "maximum": 10.0,
              "description": "Privacy budget. Lower = more private but less accurate."
            },
            "delta": {
              "type": "number",
              "default": 1e-5,
              "minimum": 1e-10,
              "maximum": 0.01
            }
          }
        },
        "zkpoc": {
          "type": "object",
          "description": "Zero-Knowledge Proof of Contribution",
          "properties": {
            "enabled": {"type": "boolean", "default": false},
            "proof_generator": {
              "type": "string",
              "enum": ["bulletproofs", "zk-snarks", "zk-starks"],
              "default": "bulletproofs"
            },
            "proof_verification_timeout_ms": {"type": "integer", "default": 100},
            "hipaa_mode": {"type": "boolean", "default": false},
            "gdpr_mode": {"type": "boolean", "default": false}
          }
        },
        "secure_aggregation": {
          "type": "boolean",
          "default": false,
          "description": "Use secure aggregation protocol"
        }
      }
    },
    "monitoring": {
      "type": "object",
      "description": "Monitoring and observability",
      "properties": {
        "prometheus_enabled": {"type": "boolean", "default": true},
        "prometheus_port": {"type": "integer", "default": 9090},
        "tensorboard": {"type": "boolean", "default": true},
        "tensorboard_dir": {"type": "string", "default": "/tmp/tensorboard_fl"},
        "log_level": {
          "type": "string",
          "enum": ["DEBUG", "INFO", "WARNING", "ERROR", "CRITICAL"],
          "default": "INFO"
        },
        "log_format": {
          "type": "string",
          "enum": ["json", "text"],
          "default": "json"
        },
        "log_rotation": {
          "type": "string",
          "enum": ["daily", "weekly", "size"],
          "default": "daily"
        },
        "log_retention_days": {"type": "integer", "default": 30},
        "health_check_interval": {"type": "integer", "default": 30},
        "checkpoint_interval": {"type": "integer", "default": 10},
        "evaluate_every_n_rounds": {"type": "integer", "default": 1},
        "metrics": {
          "type": "array",
          "items": {"type": "string"},
          "default": ["accuracy", "loss", "client_drift", "byzantine_detection"]
        }
      }
    },
    "network": {
      "type": "object",
      "description": "Network configuration",
      "properties": {
        "listen_address": {
          "type": "string",
          "default": "0.0.0.0"
        },
        "listen_port": {
          "type": "integer",
          "default": 8765,
          "minimum": 1024,
          "maximum": 65535
        },
        "max_connections": {
          "type": "integer",
          "default": 100
        },
        "connection_timeout": {
          "type": "integer",
          "default": 30,
          "description": "Connection timeout in seconds"
        },
        "heartbeat_interval": {
          "type": "integer",
          "default": 10,
          "description": "Heartbeat interval in seconds"
        }
      }
    },
    "node": {
      "type": "object",
      "description": "Node identity",
      "properties": {
        "id": {
          "type": "string",
          "default": "fl-node-001",
          "pattern": "^[a-zA-Z0-9_-]+$"
        },
        "region": {"type": "string", "default": "us-west-2"},
        "description": {"type": "string"}
      }
    },
    "system": {
      "type": "object",
      "description": "System-level configuration",
      "properties": {
        "seed": {
          "type": "integer",
          "default": 42,
          "description": "Random seed for reproducibility"
        },
        "device": {
          "type": "string",
          "enum": ["cuda", "cpu", "mps"],
          "default": "cuda"
        },
        "num_workers": {
          "type": "integer",
          "default": 4,
          "minimum": 0,
          "maximum": 32
        },
        "mixed_precision": {
          "type": "boolean",
          "default": false,
          "description": "Use mixed precision training (experimental)"
        },
        "pin_memory": {
          "type": "boolean",
          "default": true
        }
      }
    },
    "deployment": {
      "type": "object",
      "description": "Deployment mode settings",
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["production", "development", "testing"],
          "default": "development"
        },
        "dev_mode": {
          "type": "boolean",
          "default": false,
          "description": "Enable development mode with relaxed security"
        }
      }
    },
    "async_training": {
      "type": "object",
      "description": "Asynchronous training settings (experimental)",
      "properties": {
        "enabled": {"type": "boolean", "default": false},
        "staleness_threshold": {
          "type": "integer",
          "default": 5,
          "description": "Maximum rounds a client can be behind"
        },
        "buffer_size": {"type": "integer", "default": 3}
      }
    },
    "attack_simulation": {
      "type": "object",
      "description": "Byzantine attack simulation for testing",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable attack simulation (testing only)"
        },
        "num_byzantine": {"type": "integer", "default": 2},
        "byzantine_ratio": {
          "type": "number",
          "default": 0.33,
          "minimum": 0.0,
          "maximum": 0.5,
          "description": "Fraction of Byzantine nodes. BFT requires < 1/3."
        },
        "attack_type": {
          "type": "string",
          "enum": ["sign_flip", "gaussian", "backdoor", "noise", "random", "zero", "scaling_x100", "collusion", "sybil_flip", "sleeper_agent", "targeted_neuron", "noise_masked"],
          "default": "sign_flip"
        },
        "attack_magnitude": {"type": "number", "default": 2.0}
      }
    },
    "experiment": {
      "type": "object",
      "description": "Experiment configuration for research runs",
      "properties": {
        "name": {"type": "string"},
        "seeds": {
          "type": "array",
          "items": {"type": "integer"},
          "default": [42, 1337]
        },
        "defenses": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["fedavg", "coord_median", "coord_median_safe", "rfa", "fltrust", "boba", "cbf", "pogq_v4_1", "krum", "trimmed_mean"]
          }
        },
        "statistics": {
          "type": "object",
          "properties": {
            "alpha": {"type": "number", "default": 0.10},
            "margin": {"type": "number", "default": 0.02},
            "mondrian_profiles": {
              "type": "array",
              "items": {"type": "string"},
              "default": ["label"]
            }
          }
        }
      }
    },
    "targets": {
      "type": "object",
      "description": "Performance targets",
      "properties": {
        "accuracy": {
          "type": "number",
          "default": 70.0,
          "description": "Target model accuracy %"
        },
        "compression_ratio": {
          "type": "number",
          "default": 40.0,
          "description": "Target communication compression ratio"
        },
        "false_positive_rate": {
          "type": "number",
          "default": 0.05,
          "description": "Target Byzantine detection false positive rate"
        },
        "detection_rate": {
          "type": "number",
          "default": 0.90,
          "description": "Target Byzantine detection true positive rate"
        }
      }
    }
  },
  "required": ["byzantine_detection"],
  "$defs": {
    "critical_warning": {
      "description": "CRITICAL: Using LABEL_SKEW_COS_MIN=-0.3 instead of -0.5 causes 16x performance degradation (57-92% FP vs 3.55-7.1% FP). Always source .env.optimal before running tests."
    }
  }
}
