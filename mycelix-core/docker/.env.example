# =============================================================================
# Mycelix-Core Docker Environment Configuration
# =============================================================================
# Copy this file to .env and customize for your deployment

# -----------------------------------------------------------------------------
# Core Settings
# -----------------------------------------------------------------------------
MYCELIX_VERSION=0.1.0
ENVIRONMENT=development
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Coordinator Settings
# -----------------------------------------------------------------------------
COORDINATOR_HOST=0.0.0.0
COORDINATOR_PORT=8080
COORDINATOR_WORKERS=4

# Byzantine Fault Tolerance
BFT_THRESHOLD=0.33
MIN_NODES_FOR_AGGREGATION=3
AGGREGATION_TIMEOUT_SECONDS=300

# Model Settings
MODEL_VERSION=1.0.0
INITIAL_LEARNING_RATE=0.01
DIFFERENTIAL_PRIVACY_EPSILON=1.0
DIFFERENTIAL_PRIVACY_DELTA=0.00001

# -----------------------------------------------------------------------------
# Node Settings
# -----------------------------------------------------------------------------
NODE_COUNT=5
NODE_MEMORY_LIMIT=512m
NODE_CPU_LIMIT=0.5

# Secure Aggregation
SECURE_AGGREGATION_ENABLED=true
SECRET_SHARING_THRESHOLD=3

# -----------------------------------------------------------------------------
# PostgreSQL Settings
# -----------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=mycelix
POSTGRES_USER=mycelix
POSTGRES_PASSWORD=mycelix_secure_password_change_me

# Connection Pool
POSTGRES_POOL_SIZE=10
POSTGRES_MAX_OVERFLOW=20

# -----------------------------------------------------------------------------
# Redis Settings
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_secure_password_change_me
REDIS_DB=0

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_BURST=20

# -----------------------------------------------------------------------------
# Prometheus Settings
# -----------------------------------------------------------------------------
PROMETHEUS_PORT=9090
PROMETHEUS_RETENTION_DAYS=15

# -----------------------------------------------------------------------------
# Grafana Settings
# -----------------------------------------------------------------------------
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin_change_me
GRAFANA_ALLOW_ANONYMOUS=false

# -----------------------------------------------------------------------------
# Holochain Settings (Optional)
# -----------------------------------------------------------------------------
HOLOCHAIN_ENABLED=false
HOLOCHAIN_CONDUCTOR_PORT=8888
HOLOCHAIN_ADMIN_PORT=8889
HOLOCHAIN_BOOTSTRAP_URL=

# -----------------------------------------------------------------------------
# Security Settings
# -----------------------------------------------------------------------------
# JWT for API authentication
JWT_SECRET=your_jwt_secret_change_me_in_production
JWT_EXPIRY_HOURS=24

# TLS/SSL (for production)
TLS_ENABLED=false
TLS_CERT_PATH=/certs/server.crt
TLS_KEY_PATH=/certs/server.key

# -----------------------------------------------------------------------------
# Metrics & Monitoring
# -----------------------------------------------------------------------------
METRICS_ENABLED=true
METRICS_PORT=9100
TRACING_ENABLED=false
TRACING_ENDPOINT=http://jaeger:14268/api/traces

# -----------------------------------------------------------------------------
# Resource Limits
# -----------------------------------------------------------------------------
COORDINATOR_MEMORY_LIMIT=2g
COORDINATOR_CPU_LIMIT=2
POSTGRES_MEMORY_LIMIT=1g
REDIS_MEMORY_LIMIT=512m
