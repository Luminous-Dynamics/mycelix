# =============================================================================
# MYCELIX LOCAL DEVELOPMENT CONFIGURATION
# =============================================================================
#
# Copy this file to .env.local for local development:
#   cp .env.example .env.local
#
# For testnet/production deployment, see deployment/.env.example
#
# IMPORTANT: Never commit .env.local to version control!
# =============================================================================

# =============================================================================
# DATABASE
# =============================================================================

# PostgreSQL connection (from docker-compose.dev.yml)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mycelix

# Redis connection
REDIS_URL=redis://localhost:6379

# =============================================================================
# LOGGING
# =============================================================================

# Rust log levels: error, warn, info, debug, trace
# Format: module=level, e.g., mycelix=debug,hyper=warn
RUST_LOG=info,mycelix=debug

# Backtrace: 0 (off), 1 (basic), full
RUST_BACKTRACE=1

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Enable Prometheus metrics endpoint
ENABLE_METRICS=true

# Enable distributed tracing (requires Jaeger)
ENABLE_TRACING=false

# Enable differential privacy in FL
ENABLE_DP=true

# Enable homomorphic encryption (performance impact)
ENABLE_HE=false

# =============================================================================
# FL AGGREGATOR
# =============================================================================

# Byzantine fault tolerance threshold (45% = Mycelix breakthrough)
FL_BYZANTINE_THRESHOLD=0.45

# Minimum participants for FL round
FL_MIN_PARTICIPANTS=3

# Privacy budget (epsilon) for differential privacy
FL_PRIVACY_EPSILON=1.0

# =============================================================================
# VALIDATOR
# =============================================================================

# Local validator node ID
VALIDATOR_NODE_ID=validator-local-dev

# Reputation threshold for block production
REPUTATION_THRESHOLD=0.5

# =============================================================================
# ZK PROOFS
# =============================================================================

# Enable ZK proof generation
ZK_ENABLED=true

# Proof system: stark (default) or groth16
ZK_PROOF_SYSTEM=stark

# =============================================================================
# HOLOCHAIN (if running locally)
# =============================================================================

# Conductor admin port
HC_ADMIN_PORT=39329

# Application WebSocket port
HC_APP_PORT=9998

# =============================================================================
# DEVELOPMENT ONLY
# =============================================================================

# Skip signature verification (DEV ONLY - never in production!)
# DEV_SKIP_SIGNATURES=false

# Mock Byzantine behavior for testing
# DEV_MOCK_BYZANTINE=false

# Seed for reproducible random behavior in tests
# DEV_RANDOM_SEED=12345
