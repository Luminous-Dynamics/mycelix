{
  "name": "@mycelix/governance-sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for Mycelix Governance with Collective Mirror integration",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest"
  },
  "keywords": [
    "mycelix",
    "governance",
    "holochain",
    "collective-intelligence",
    "swarm-wisdom",
    "phi-voting",
    "quadratic-voting",
    "decentralized"
  ],
  "author": "Luminous Dynamics",
  "license": "MIT",
  "peerDependencies": {
    "@holochain/client": ">=0.17.0"
  },
  "devDependencies": {
    "@holochain/client": "^0.17.0",
    "@types/node": "^20.0.0",
    "eslint": "^9.39.2",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^4.0.18"
  }
}
